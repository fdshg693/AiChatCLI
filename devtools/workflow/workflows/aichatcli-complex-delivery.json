{
  "schema_version": 1,
  "name": "aichatcli-complex-delivery",
  "run_name": "aichatcli-complex-delivery",
  "description": "Write-enabled workflow archetype for survey, planning, implementation, review, and review fixes.",
  "variables_file": "complex-delivery.json",
  "defaults": {
    "command": "cursor-agent",
    "workspace": "../../..",
    "cwd": "../../..",
    "mode": null,
    "output_format": "text",
    "print_mode": true,
    "force": true,
    "yolo": true,
    "sandbox": "disabled",
    "approve_mcps": false,
    "trust": false,
    "extra_args": []
  },
  "steps": [
    {
      "name": "repository-survey",
      "prompt": "${file:repository-survey.md}",
      "mode": "ask",
      "force": false,
      "yolo": false
    },
    {
      "name": "plan-approach",
      "prompt": "${file:plan-approach.md}",
      "mode": "plan",
      "force": false,
      "yolo": false
    },
    {
      "name": "implement",
      "prompt": "${file:implement.md}"
    },
    {
      "name": "review",
      "prompt": "${file:review.md}",
      "mode": "ask",
      "force": false,
      "yolo": false
    },
    {
      "name": "apply-review-fixes",
      "prompt": "${file:apply-review-fixes.md}"
    }
  ]
}
